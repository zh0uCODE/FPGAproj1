# ============================================================
# FPGA Open-Source Toolchain — .gitignore
# Policy: track only scripts/docs/project sources; do not track
# tool binaries or build artifacts.
# Rebuild the toolchain on a new machine per docs/SOP-macos-fpga-toolchain.md
# ============================================================

# --- oss-cad-suite prebuilt package ---
tools/oss-cad-suite/

# --- nextpnr-xilinx external repo (cloned from openXC7, rebuild per SOP) ---
tools/nextpnr-xilinx-src/

# --- prjxray external repo (cloned from f4pga, rebuild per SOP) ---
tools/prjxray/

# --- Python cache ---
__pycache__/
*.pyc
*.pyo

# --- macOS junk files ---
.DS_Store
.AppleDouble
._*

# --- Editors ---
*.swp
*.swo
*~
.vscode/
.idea/

# --- Build intermediates ---
*.o
*.a
*.so
*.dylib

# --- FPGA project generated files ---
projects/*/*.json
projects/*/*.fasm
projects/*/*.frames
projects/*/*.bit
projects/*/*.bin
